# Copy this file to .env and fill values. Never commit .env.
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=use_a_strong_private_password
JWT_SECRET=use_a_long_random_private_secret
APP_NAME=Anime Nova Instagram Manager
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./anime_nova.db
META_GRAPH_VERSION=v20.0
INSTAGRAM_USER_ID=YOUR_INSTAGRAM_BUSINESS_USER_ID
META_ACCESS_TOKEN=PASTE_FULL_VALID_TOKEN_HERE
BRAND_WATERMARK=Anim.funzon
MIN_CONTENT_PER_DAY=3
MAX_CONTENT_PER_DAY=5
AUTO_PUBLISH_ENABLED=false
AI_PROVIDER=rules
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
GROQ_API_KEY=PASTE_GROQ_API_KEY_HERE
MEDIA_INPUT_DIR=./media/input
MEDIA_OUTPUT_DIR=./media/output
